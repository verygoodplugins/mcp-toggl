{
  "name": "@verygoodplugins/mcp-toggl",
  "version": "1.0.0",
  "description": "MCP server for Toggl Track integration with time tracking and reporting",
  "main": "dist/index.js",
  "type": "module",
  "mcpName": "io.github.verygoodplugins/mcp-toggl",
  "bin": {
    "mcp-toggl": "dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "postbuild": "chmod +x dist/index.js",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "setup": "node scripts/setup.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "format": "prettier --write src/**/*.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "modelcontextprotocol",
    "toggl",
    "time-tracking",
    "reporting",
    "productivity"
  ],
  "author": "Very Good Plugins",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/verygoodplugins/mcp-toggl.git"
  },
  "homepage": "https://github.com/verygoodplugins/mcp-toggl#readme",
  "bugs": {
    "url": "https://github.com/verygoodplugins/mcp-toggl/issues"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "docs/images/*.svg",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "node-fetch": "^3.3.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.1.0",
    "tsx": "^4.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
